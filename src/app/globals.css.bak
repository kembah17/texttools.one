@import "tailwindcss";

@custom-variant dark (&:where(.dark, .dark *));

/* Tailwind utility class mappings - uses actual values for build-time resolution */
@theme inline {
  --color-primary: #4F46E5;
  --color-primary-light: #B2AEF3;
  --color-primary-dark: #281ED6;
  --color-primary-hover: #281ED6;
  --color-primary-text: #0F1419;
  --color-secondary: #FDFDFE;
  --color-accent: #4F46E5;
  --color-accent-dark: #281ED6;
  --color-surface: #FFFFFF;
  --color-surface-alt: #F3F4F6;
  --color-surface-dark: #0B1120;
  --color-surface-dark-alt: #162032;
  --color-card: #FFFFFF;
  --color-card-hover: #F9FAFB;
  --color-input: #FFFFFF;
  --color-hero: #FFFFFF;
  --color-page-bg: #EBEDF2;
  --color-page-bg-dark: #0B1120;
  --color-text: #0F1419;
  --color-text-light: #1E293B;
  --color-text-dark: #FFFFFF;
  --color-text-dark-muted: #94A3B8;
  --color-heading: #0F1419;
  --color-link: #4F46E5;
  --color-dark: #FFFFFF;
  --color-dark-muted: #94A3B8;
  --color-light: #FFFFFF;
  --color-muted: #475569;
  --color-border: #B8BCC8;
  --color-border-light: #D1D5DB;
  --color-border-dark: #475569;
  --color-success: #047857;
  --color-success-bg: #ECFDF5;
  --color-warning: #B45309;
  --color-warning-bg: #FFFBEB;
  --color-error: #DC2626;
  --color-error-bg: #FEF2F2;
  --color-info: #2563EB;
  --color-info-bg: #EFF6FF;
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
}

:root {
  --color-bg-primary: #EBEDF2;
  --color-bg-secondary: #DFE1E8;
  --color-bg-card: #FFFFFF;
  --color-bg-card-hover: #F9FAFB;
  --color-bg-input: #FFFFFF;
  --color-bg-hero: linear-gradient(180deg, #FFFFFF 0%, #FFFFFF 100%);
  --color-bg-hero-solid: #FFFFFF;
  --color-bg-muted: #F3F4F6;
  --color-bg-code: #F3F4F6;
  --color-text-primary: #0F1419;
  --color-text-secondary: #1E293B;
  --color-text-tertiary: #334155;
  --color-text-muted: #475569;
  --color-text-inverse: #F1F5F9;
  --color-text-heading: #0F1419;
  --color-text-link: #4F46E5;
  --color-brand: #4F46E5;
  --color-brand-dark: #281ED6;
  --color-brand-darker: #2017AA;
  --color-brand-light: #B2AEF3;
  --color-brand-lighter: #FDFDFE;
  --color-brand-lightest: #FFFFFF;
  --color-brand-bg: #FFFFFF;
  --color-border: #B8BCC8;
  --color-border-light: #D1D5DB;
  --color-border-dark: #8892A4;
  --color-border-brand: #4F46E5;
  --shadow-sm: 0 1px 3px 0 rgba(0,0,0,0.08), 0 1px 2px -1px rgba(0,0,0,0.06);
  --shadow-md: 0 4px 8px -1px rgba(0,0,0,0.12), 0 2px 4px -2px rgba(0,0,0,0.08);
  --shadow-lg: 0 12px 24px -4px rgba(0,0,0,0.15), 0 4px 8px -4px rgba(0,0,0,0.1);
  --shadow-card: 0 2px 8px -2px rgba(0,0,0,0.1), 0 1px 3px -1px rgba(0,0,0,0.06);
  --color-success: #047857;
  --color-success-bg: #ECFDF5;
  --color-warning: #B45309;
  --color-warning-bg: #FFFBEB;
  --color-error: #DC2626;
  --color-error-bg: #FEF2F2;
  --color-info: #2563EB;
  --color-info-bg: #EFF6FF;
  --color-ad-bg: rgba(79,70,229,0.04);
  --color-ad-border: rgba(79,70,229,0.12);
  --color-ad-text: #6B7280;
  --color-toggle-track: #CBD5E1;
  --color-toggle-thumb: #FFFFFF;
  --color-toggle-icon: #64748B;
  --color-footer-bg: #111827;
  --color-footer-text: #E2E8F0;
  --color-footer-muted: #94A3B8;
  --color-footer-border: #1F2937;
  --color-footer-link: #B2AEF3;
  --color-footer-link-hover: #4F46E5;
}

.dark {
  /* @theme variable overrides for dark mode */
  --color-text: #F1F5F9;
  --color-text-light: #CBD5E1;
  --color-heading: #F8FAFC;
  --color-muted: #94A3B8;
  --color-card: #1A2538;
  --color-card-hover: #243044;
  --color-surface: #162032;
  --color-surface-alt: #1E2D42;
  --color-input: #1A2538;
  --color-page-bg: #0B1120;
  --color-light: #FFFFFF;
  --color-dark: #FFFFFF;
  --color-dark-muted: #94A3B8;
  --color-link: #B2AEF3;

  --color-primary-text: #FFFFFF;
  --color-bg-primary: #0B1120;
  --color-bg-secondary: #162032;
  --color-bg-card: #1A2538;
  --color-bg-card-hover: #243044;
  --color-bg-input: #1A2538;
  --color-bg-hero: linear-gradient(180deg, #090734 0%, #05041F 100%);
  --color-bg-hero-solid: #090734;
  --color-bg-muted: #1A2538;
  --color-bg-code: #1A2538;
  --color-text-primary: #F1F5F9;
  --color-text-secondary: #CBD5E1;
  --color-text-tertiary: #94A3B8;
  --color-text-muted: #94A3B8;
  --color-text-inverse: #111827;
  --color-text-heading: #F8FAFC;
  --color-text-link: #B2AEF3;
  --color-brand: #B2AEF3;
  --color-brand-dark: #4F46E5;
  --color-brand-darker: #281ED6;
  --color-brand-light: #FDFDFE;
  --color-brand-lighter: #FFFFFF;
  --color-brand-lightest: #0C0941;
  --color-brand-bg: #0C0941;
  --color-border: #475569;
  --color-border-light: #1E2D42;
  --color-border-dark: #3D5068;
  --color-border-brand: #4F46E5;
  --shadow-sm: 0 1px 3px 0 rgba(0,0,0,0.4), 0 1px 2px -1px rgba(0,0,0,0.3);
  --shadow-md: 0 4px 8px -1px rgba(0,0,0,0.5), 0 2px 4px -2px rgba(0,0,0,0.4);
  --shadow-lg: 0 12px 24px -4px rgba(0,0,0,0.5), 0 4px 8px -4px rgba(0,0,0,0.4);
  --shadow-card: 0 2px 8px -2px rgba(0,0,0,0.4), 0 1px 3px -1px rgba(0,0,0,0.3);
  --color-success: #34D399;
  --color-success-bg: #064E3B;
  --color-warning: #FBBF24;
  --color-warning-bg: #78350F;
  --color-error: #F87171;
  --color-error-bg: #7F1D1D;
  --color-info: #60A5FA;
  --color-info-bg: #1E3A5F;
  --color-ad-bg: rgba(178,174,243,0.06);
  --color-ad-border: rgba(178,174,243,0.15);
  --color-ad-text: #94A3B8;
  --color-toggle-track: #334155;
  --color-toggle-thumb: #F1F5F9;
  --color-toggle-icon: #94A3B8;
  --color-footer-bg: #030712;
  --color-footer-text: #E2E8F0;
  --color-footer-muted: #94A3B8;
  --color-footer-border: #111827;
  --color-footer-link: #818CF8;
  --color-footer-link-hover: #B2AEF3;
}

* { box-sizing: border-box; }

body {
  background-color: var(--color-bg-primary);
  color: var(--color-text-primary);
  font-family: system-ui, -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

::selection { background-color: var(--color-brand-lighter); color: var(--color-text-primary); }
.dark ::selection { background-color: var(--color-brand-darker); color: var(--color-text-primary); }

input, textarea, select { background-color: var(--color-bg-input); color: var(--color-text-primary); border-color: var(--color-border); }
input:focus, textarea:focus, select:focus { outline: none; border-color: var(--color-brand); box-shadow: 0 0 0 3px rgba(79,70,229,0.15); }
.dark input:focus, .dark textarea:focus, .dark select:focus { box-shadow: 0 0 0 3px rgba(178,174,243,0.2); }
